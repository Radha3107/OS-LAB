#include<stdio.h>

int main()
{
    int bt[10], rt[10], n, i, time = 0, remain, flag = 0;
    int wt = 0, tat = 0;

    printf("Enter number of processes: ");
    scanf("%d",&n);

    remain = n;

    for(i=0;i<n;i++)
    {
        printf("Enter burst time: ");
        scanf("%d",&bt[i]);
        rt[i] = bt[i];
    }

    while(remain != 0)
    {
        int smallest = 0;

        for(i=1;i<n;i++)
        {
            if(rt[i] < rt[smallest] && rt[i] > 0)
                smallest = i;
        }

        rt[smallest]--;

        if(rt[smallest] == 0)
        {
            remain--;
            wt += time + 1 - bt[smallest];
            tat += time + 1;
        }

        time++;
    }

    printf("Average WT = %f\n",(float)wt/n);
    printf("Average TAT = %f\n",(float)tat/n);

    return 0;
}
